# ph-cdr environment configuration
# Copy this file to .env and uncomment lines to override defaults.
# These values are passed to the HAPI container and interpolated in hapi/application.yaml.
# The .env file is gitignored — do not commit version pins or credentials.

# Philippine Core IG version
# Matches the package published at https://jgsuess.github.io/ph-core/<version>/package.tgz
# Default: 0.1.1
# PH_CORE_VERSION=0.1.1

# Philippine eReferral IG version
# Matches the package published at https://jgsuess.github.io/ph-ereferral/<version>/package.tgz
# Default: 0.3.1
# PH_EREFERRAL_VERSION=0.3.1
